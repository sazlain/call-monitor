# ══════════════════════════════════════════════════════════════════════════════
#  .env.example — Backend (Call Monitor / ZentCall)
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas el .env real al repositorio.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=cambia-esta-password
POSTGRES_DB=call_manager_db
POSTGRES_PORT=5432

# ── Aplicación ────────────────────────────────────────────────────────────────
# Puerto donde escucha el backend (8080 por defecto)
APP_PORT=8080

# Directorio donde se guardan los archivos subidos (comprobantes de pago, etc.)
# En Docker se monta como volumen: /app/uploads
# En local puedes usar: ./uploads
APP_UPLOADS_DIR=./uploads

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT — mínimo 32 caracteres
JWT_SECRET=cambia-este-secret-por-uno-seguro-de-minimo-32-chars

# Clave maestra requerida en el header X-Admin-Secret para crear nuevos admins
APP_ADMIN_SECRET=clave-admin-muy-segura-cambiar-en-produccion

# ── Webhook de telefonía ───────────────────────────────────────────────────────
# IPs permitidas para recibir eventos del proveedor (Net2Phone u otro)
# Usa * para permitir todas las IPs mientras configuras el proveedor
WEBHOOK_ALLOWED_IPS=*

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (separados por comas)
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# ── Email SMTP ────────────────────────────────────────────────────────────────
# Configuración del servidor de correo para envío de notificaciones
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-correo@gmail.com
# Para Gmail, genera una "Contraseña de aplicación" en tu cuenta de Google
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Genera tus propias claves VAPID en: https://web-push-codelab.glitch.me/
# o con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=TU_CLAVE_PUBLICA_VAPID_AQUI
VAPID_PRIVATE_KEY=TU_CLAVE_PRIVADA_VAPID_AQUI
VAPID_SUBJECT=mailto:tu-correo@tudominio.com

# ── Super Administrador inicial ────────────────────────────────────────────────
# Se crea automáticamente al arrancar si no existe en la base de datos
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=superadmin@tudominio.com
SUPER_ADMIN_PASSWORD=CambiaEstaPassword-1234
